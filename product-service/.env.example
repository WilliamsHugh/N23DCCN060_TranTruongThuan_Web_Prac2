# .evn.example
NODE_ENV=development
PORT=3001
SERVICE_NAME=product-service
# PostgreSQL — lấy từ Supabase dashboard
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres"

# Dùng connection pooling cho production
DATABASE_URL_POOL="postgresql://postgres.[PROJECT]:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"